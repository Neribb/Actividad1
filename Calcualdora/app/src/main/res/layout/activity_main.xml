<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="bottom">

    <EditText
        android:id="@+id/etPantalla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="40sp"
        android:hint="0"
        android:gravity="end"
        android:inputType="none"
        android:focusable="false"
        android:background="@android:color/transparent"
        android:layout_marginBottom="20dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5"
        android:alignmentMode="alignMargins">

        <Button android:id="@+id/btnC" android:text="C" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btnDiv" android:text="/" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btnMult" android:text="*" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btnBorrar" android:text="DEL" android:layout_columnWeight="1"/>

        <Button android:id="@+id/btn7" android:text="7" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btn8" android:text="8" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btn9" android:text="9" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btnResta" android:text="-" android:layout_columnWeight="1"/>

        <Button android:id="@+id/btn4" android:text="4" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btn5" android:text="5" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btn6" android:text="6" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btnSuma" android:text="+" android:layout_columnWeight="1"/>

        <Button android:id="@+id/btn1" android:text="1" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btn2" android:text="2" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btn3" android:text="3" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btnIgual" android:text="=" android:layout_rowSpan="2" android:layout_gravity="fill" android:layout_columnWeight="1"/>

        <Button android:id="@+id/btn0" android:text="0" android:layout_columnSpan="3" android:layout_gravity="fill"/>

    </GridLayout>
</LinearLayout>